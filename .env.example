# VRO SEO Analyzer — Environment Variables
# Copy this file to .env and fill in your values

# Payload CMS (required)
PAYLOAD_BASE_URL=https://www.vitalrecordsonline.com
PAYLOAD_API_PATH=/api-cms
PAYLOAD_EMAIL=your-email@example.com
PAYLOAD_PASSWORD=your-password-here

# Ahrefs API (optional — enriches scores with backlink/traffic data)
AHREFS_API_TOKEN=

# SEMrush API (optional — enriches scores with keyword ranking data)
SEMRUSH_API_KEY=

# DeepSeek API (optional — AI-powered SEO recommendations)
# Get your key at https://platform.deepseek.com/api_keys
DEEPSEEK_API_KEY=

# Server port (Railway sets this automatically)
PORT=3847
